# Vidra environment template.
# Copy to .env and fill in real values. Never commit .env.
# Required vars are marked [REQUIRED]; everything else has working defaults.

# ─── LLM Providers ──────────────────────────────────────────────────────────
# [REQUIRED] OpenAI — refinement stage and span labeling fallback.
OPENAI_API_KEY=sk-proj-REPLACE_ME
OPENAI_MODEL=gpt-4o-mini
OPENAI_TIMEOUT_MS=60000

# [REQUIRED] Groq — ultra-fast draft stage of two-stage optimization (~300ms).
GROQ_API_KEY=gsk_REPLACE_ME
GROQ_MODEL=llama-3.1-8b-instant
GROQ_TIMEOUT_MS=5000

# [REQUIRED] Google Gemini — primary span-labeling provider.
GOOGLE_API_KEY=REPLACE_ME
GEMINI_API_KEY=REPLACE_ME
GEMINI_MODEL=gemini-2.5-flash
SPAN_PROVIDER=gemini
SPAN_MODEL=gemini-2.5-flash

# [REQUIRED for image preview] Replicate — Flux Schnell image generation.
REPLICATE_API_TOKEN=r8_REPLACE_ME

# [Optional] Luma — Dream Machine video generation.
LUMA_API_KEY=luma-REPLACE_ME

# [Optional] Fal — Wan 2.2 / face swap. Both vars share the same value.
FAL_API_KEY=REPLACE_ME
FAL_KEY=${FAL_API_KEY}

# ─── Firebase (client) ──────────────────────────────────────────────────────
# [REQUIRED] All VITE_FIREBASE_* are exposed to the client by Vite.
VITE_FIREBASE_API_KEY=REPLACE_ME
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project
VITE_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=000000000000
VITE_FIREBASE_APP_ID=1:000000000000:web:replace_me
VITE_FIREBASE_MEASUREMENT_ID=G-REPLACE_ME

# ─── Firebase Admin (server) ────────────────────────────────────────────────
# [REQUIRED] Path to Firebase Admin SDK service account JSON. Keep file outside git.
FIREBASE_SERVICE_ACCOUNT_PATH=./server/.secrets/your-firebase-adminsdk.json

# ─── Server Runtime ─────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3001
FRONTEND_URL=http://localhost:5173
LOG_LEVEL=warn

# Comma-separated allowed API keys. Generate prod keys via: openssl rand -hex 32
ALLOWED_API_KEYS=dev-key-12345
VITE_API_KEY=dev-key-12345

# Bearer token for /metrics and /stats. Generate via: openssl rand -base64 32
METRICS_TOKEN=replace-with-strong-random-token

# Comma-separated origins allowed by CORS in production.
ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# Grafana admin password (only used by docker monitoring stack).
GRAFANA_ADMIN_PASSWORD=replace-with-strong-password

# ─── Sentry ─────────────────────────────────────────────────────────────────
SENTRY_DSN=https://REPLACE_ME@sentry.io/REPLACE_ME
VITE_SENTRY_DSN=https://REPLACE_ME@sentry.io/REPLACE_ME
VITE_ENVIRONMENT=development
VITE_APP_VERSION=1.0.0
VITE_SENTRY_DEBUG=true
SENTRY_DEBUG=true

# ─── Logging ────────────────────────────────────────────────────────────────
VITE_DEBUG_LOGGING=false
VITE_LOG_LEVEL=warn
LOG_STACK=true
VITE_LOG_STACK=true
LOG_STACK_LEVELS=warn,error
VITE_LOG_STACK_LEVELS=warn,error
LOG_STACK_DEPTH=20
VITE_LOG_STACK_DEPTH=20
LOG_STACK_LIMIT=50
VITE_LOG_STACK_LIMIT=50

# ─── Stripe ─────────────────────────────────────────────────────────────────
# JSON map of Stripe price ID → credits. Update when prices change.
STRIPE_PRICE_CREDITS={"price_explorer_monthly":500,"price_creator_monthly":1800,"price_agency_monthly":6000,"price_credits_250":300,"price_credits_500":600,"price_credits_1000":1200,"price_credits_2500":3000}

# ─── Google Cloud Storage ───────────────────────────────────────────────────
# [REQUIRED] Path to GCS service account JSON. Must be gitignored.
GOOGLE_APPLICATION_CREDENTIALS=./gcs-service-account.json
VIDEO_STORAGE_BUCKET=your-media-bucket
IMAGE_STORAGE_BUCKET=your-media-bucket
GCS_BUCKET_NAME=your-media-bucket
ASSET_STORAGE_BUCKET=your-media-bucket

# ─── Process Role & Worker Tuning ───────────────────────────────────────────
# api: serves user traffic, no worker loops.
# worker: runs background video worker / sweeper loops.
PROCESS_ROLE=api

VIDEO_JOB_INLINE_ENABLED=false
VIDEO_WORKER_SHUTDOWN_DRAIN_SECONDS=45

VIDEO_JOB_MAX_ATTEMPTS=3
VIDEO_JOB_LEASE_SECONDS=60
VIDEO_JOB_HEARTBEAT_INTERVAL_MS=20000
VIDEO_JOB_STALE_QUEUE_SECONDS=300
VIDEO_JOB_STALE_PROCESSING_SECONDS=90
VIDEO_JOB_SWEEP_INTERVAL_SECONDS=15
VIDEO_PROVIDER_POLL_TIMEOUT_MS=270000
VIDEO_WORKFLOW_TIMEOUT_MS=300000

# ─── OpenTelemetry (optional) ───────────────────────────────────────────────
# Set OTEL_EXPORTER_OTLP_ENDPOINT to enable OTLP export (Jaeger, Tempo, Datadog).
# When unset, traces go to console (dev mode).
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
# OTEL_EXPORTER_OTLP_HEADERS=Authorization=Bearer your_token
# OTEL_EXPORTER_OTLP_TIMEOUT=10000

# ─── Feature Flags (see CLAUDE.md for full list) ────────────────────────────
# Defaults are sane; only override to disable specific subsystems.
# ENABLE_CONVERGENCE=true
# WEBHOOK_RECONCILIATION_ENABLED=true
# CREDIT_RECONCILIATION_ENABLED=true
# VIDEO_JOB_SWEEPER_ENABLED=true
