{
  "meta": {
    "project": "Vidra",
    "tagline": "Interactive editing canvas for AI video prompts with semantic span labeling, click-to-enhance suggestions, and fast previews.",
    "stage": "pre-launch (zero users)",
    "generatedAt": "2026-05-19",
    "sourceOfTruth": [
      "CLAUDE.md",
      "client/CLAUDE.md",
      "server/CLAUDE.md",
      "server/src/config/feature-flags.ts",
      "server/src/config/services.config.ts",
      "server/src/routes/api.routes.ts",
      "package.json"
    ]
  },
  "runtime": {
    "node": ">=20",
    "moduleSystem": "ESM",
    "languages": ["TypeScript", "JavaScript (migration in progress)"],
    "monorepo": true,
    "workspaces": ["packages/*"],
    "ports": {
      "vite": 5173,
      "express": 3001
    },
    "proxy": "Vite dev server proxies /api → :3001",
    "envRequired": [
      "One of: FIREBASE_SERVICE_ACCOUNT_JSON, FIREBASE_SERVICE_ACCOUNT_PATH, GOOGLE_APPLICATION_CREDENTIALS"
    ],
    "envOptional": [
      "REDIS_URL (falls back to in-memory cache)",
      "STRIPE_SECRET_KEY",
      "OPENAI_API_KEY",
      "GROQ_API_KEY",
      "GEMINI_API_KEY",
      "REPLICATE_API_TOKEN",
      "FAL_KEY",
      "LUMAAI_API_KEY",
      "SENTRY_DSN",
      "POSTHOG_API_KEY"
    ],
    "startupProbe": "Express runs admin.auth().listUsers() and firestore.listCollections() at startup. Skipped only when NODE_ENV=test."
  },
  "techStack": {
    "client": {
      "framework": "React 18 + Vite 5",
      "language": "TypeScript / JavaScript (migration in progress)",
      "styling": ["Tailwind CSS", "DaisyUI", "Radix UI primitives"],
      "icons": "lucide-react",
      "routing": "react-router-dom v7",
      "validation": "Zod 4",
      "testing": ["Vitest", "Playwright", "@testing-library/react"]
    },
    "server": {
      "runtime": "Node.js 20",
      "framework": "Express 4",
      "executor": "tsx (TypeScript execution)",
      "logging": "Pino + pino-pretty",
      "validation": "Zod 4",
      "errorTracking": "Sentry",
      "observability": ["OpenTelemetry SDK", "PostHog"],
      "auth": "Firebase Admin",
      "payments": "Stripe",
      "storage": "Google Cloud Storage",
      "cache": "ioredis (optional, in-memory fallback)",
      "circuit-breaker": "opossum",
      "ai-runtime": [
        "openai",
        "@huggingface/transformers",
        "onnxruntime-node",
        "gliner",
        "compromise"
      ]
    },
    "shared": {
      "purpose": "Pure contract layer — types, Zod schemas, constants, pure utility functions ONLY (no I/O, no React, no Node APIs)",
      "import": "#shared/* (Node) or @shared/* (Vite alias)"
    }
  },
  "externalSystems": [
    {
      "name": "Firebase (Admin)",
      "purpose": "Auth + Firestore for sessions, billing profiles, telemetry sinks",
      "required": true,
      "startupProbed": true
    },
    {
      "name": "Google Cloud Storage",
      "purpose": "Asset storage (images, video, reference images)",
      "required": true,
      "startupProbed": false
    },
    {
      "name": "Stripe",
      "purpose": "Payments, billing portal, subscriptions, webhook reconciliation",
      "required": false,
      "startupProbed": false
    },
    {
      "name": "Redis",
      "purpose": "Cache + rate-limit store (falls back to in-memory when REDIS_URL unset)",
      "required": false,
      "startupProbed": false
    },
    {
      "name": "OpenAI",
      "purpose": "Refinement-stage LLM, image gen, embeddings",
      "required": "for full pipeline",
      "startupProbed": false
    },
    {
      "name": "Groq",
      "purpose": "Fast-draft LLM for two-stage optimization",
      "required": "for full pipeline",
      "startupProbed": false
    },
    {
      "name": "Google Gemini",
      "purpose": "Multimodal LLM for image observation",
      "required": false,
      "startupProbed": false
    },
    {
      "name": "Replicate",
      "purpose": "Face embedding, CLIP embedding, depth estimation",
      "required": false,
      "startupProbed": false
    },
    {
      "name": "Fal",
      "purpose": "Flux Schnell image preview, Wan 2.2 video preview",
      "required": false,
      "startupProbed": false
    },
    {
      "name": "Luma AI",
      "purpose": "Video generation (Luma Dream Machine)",
      "required": false,
      "startupProbed": false
    },
    {
      "name": "Sentry",
      "purpose": "Error tracking (Node + React + profiling)",
      "required": false,
      "startupProbed": false
    },
    {
      "name": "PostHog",
      "purpose": "Product analytics + telemetry events",
      "required": false,
      "startupProbed": false
    }
  ],
  "repository": {
    "tree": {
      "client/": "React frontend (Vite). See client/CLAUDE.md",
      "client/src/App.tsx": "Top-level router + auth gates",
      "client/src/features/": "Vertical feature slices (orchestrator + hooks + api + components)",
      "client/src/pages/": "Marketing + auth pages mounted under MarketingShell",
      "client/src/api/": "Cross-feature thin fetch wrappers",
      "client/src/services/": "Stateful client-side services (ApiClient, telemetry, prediction)",
      "client/src/repositories/": "Data access layer",
      "client/src/contexts/": "React context providers",
      "client/src/schemas/": "Client-side Zod schemas",
      "server/": "Express API + background workers. See server/CLAUDE.md",
      "server/index.ts": "Entry point",
      "server/src/app.ts": "Express app wiring",
      "server/src/server.ts": "HTTP server + graceful shutdown",
      "server/src/config/services/": "DI registration, domain-scoped",
      "server/src/config/feature-flags.ts": "Source of truth for env-driven flags",
      "server/src/routes/": "HTTP route handlers (thin)",
      "server/src/services/": "Business logic (domain subdirectories)",
      "server/src/llm/": "LLM orchestration: span labeling, role classifier",
      "server/src/clients/": "External API adapters (LLM providers, video providers)",
      "server/src/middleware/": "Express middleware (auth, validation, rate limit, telemetry)",
      "server/src/schemas/": "Server-side Zod schemas",
      "shared/": "Pure contract layer (types, Zod, constants, pure utils)",
      "packages/": "Workspace packages (@promptstudio/system)",
      "config/": "Build, lint, test config",
      "scripts/": "Dev tools, migrations, eval suites",
      "docs/": "Architecture docs",
      "tests/": "E2E, load, eval suites"
    }
  },
  "domains": [
    {
      "key": "span-labeling",
      "name": "Span Labeling",
      "description": "ML categorization of prompt phrases into taxonomy categories (subject, camera, lighting…) for UI highlights.",
      "serverPath": "server/src/llm/span-labeling/",
      "diFile": "span-labeling.services.ts",
      "routes": ["POST /llm/label-spans", "POST /llm/label-spans/stream"],
      "clientApi": "client/src/features/span-highlighting/api/spanLabelingApi.ts",
      "providers": ["openai", "groq"]
    },
    {
      "key": "enhancement",
      "name": "Enhancement / Suggestions",
      "description": "AI-generated alternative phrases for a user-selected span (click-to-enhance).",
      "serverPath": "server/src/services/enhancement/",
      "diFile": "enhancement.services.ts",
      "routes": [
        "POST /api/get-enhancement-suggestions",
        "POST /api/get-custom-suggestions",
        "POST /api/detect-scene-change",
        "POST /api/test-nlp"
      ],
      "clientApi": "client/src/services/EnhancementApi.ts + client/src/api/enhancementSuggestionsApi.ts",
      "providers": ["openai", "groq", "gemini"],
      "registers": [
        "enhancementService",
        "sceneDetectionService",
        "promptCoherenceService",
        "suggestionsTelemetryService",
        "videoService",
        "promptBuilder",
        "templateService"
      ]
    },
    {
      "key": "optimization",
      "name": "Prompt Optimization",
      "description": "Two-stage prompt rewriting pipeline (Groq fast draft → OpenAI refinement). Buffered streaming response.",
      "serverPath": "server/src/services/prompt-optimization/",
      "diFile": "enhancement.services.ts (alongside enhancement)",
      "routes": ["POST /api/optimize", "POST /api/optimize/stream"],
      "clientApi": "client/src/services/PromptOptimizationApi.ts",
      "providers": ["groq (draft)", "openai (refine)"],
      "registers": ["promptOptimizationService", "optimizeTelemetryService"]
    },
    {
      "key": "continuity",
      "name": "Continuity",
      "description": "Shot-to-shot visual consistency in multi-shot sequences. Gated by ENABLE_CONVERGENCE flag.",
      "serverPath": "server/src/services/continuity/",
      "diFile": "continuity.services.ts",
      "routes": [
        "POST /api/continuity (create session)",
        "GET /api/continuity (list)",
        "GET /api/continuity/:id",
        "PATCH /api/continuity/:id",
        "POST /api/continuity/:id/shots",
        "PUT /api/continuity/:id/shots/:shotId",
        "POST /api/continuity/:id/generate"
      ],
      "clientApi": "client/src/features/continuity/api/",
      "conditionalOn": "ENABLE_CONVERGENCE=true",
      "registers": [
        "continuitySessionService",
        "continuityQualityGate",
        "+10 sub-services"
      ]
    },
    {
      "key": "convergence",
      "name": "Convergence",
      "description": "Motion and visual convergence pipeline (iterative refinement toward target).",
      "serverPath": "server/src/services/convergence/",
      "diFile": "(shared with continuity / generation)",
      "routes": ["POST /api/motion/*"],
      "clientApi": "client/src/api/motionApi.ts",
      "providers": ["openai", "fal"]
    },
    {
      "key": "model-intelligence",
      "name": "Model Intelligence",
      "description": "AI-powered model recommendation based on prompt analysis. Scores candidate video models against prompt requirements.",
      "serverPath": "server/src/services/model-intelligence/",
      "diFile": "(registered conditionally in api.routes.ts wiring)",
      "routes": [
        "POST /api/model-intelligence/recommend",
        "POST /api/model-intelligence/explain"
      ],
      "clientApi": "client/src/features/model-intelligence/api/",
      "providers": ["openai (analysis)", "deterministic scoring"]
    },
    {
      "key": "preview",
      "name": "Preview (Image + Video Drafts)",
      "description": "Image (Flux Schnell via Fal) and video (Wan 2.2 via Fal) draft generation before final render.",
      "serverPath": "server/src/services/image-generation/, server/src/services/video-generation/",
      "diFile": "video-generation.services.ts",
      "routes": [
        "POST /api/preview/generate (image)",
        "POST /api/preview/video/generate",
        "POST /api/preview/face-swap",
        "GET /api/preview/video/jobs/:jobId",
        "GET /api/preview/video/content/:contentId",
        "GET /api/preview/image/content/:contentId",
        "GET /api/preview/video/availability",
        "GET /api/preview/image/view",
        "POST /api/preview/image/view-batch",
        "GET /api/preview/video/view"
      ],
      "clientApi": "client/src/features/preview/api/",
      "providers": ["fal (flux-schnell, wan-2.2)", "replicate"]
    },
    {
      "key": "generation",
      "name": "Generation (Final Render)",
      "description": "Final video render via Sora, Veo, Kling, Luma, Runway (recommendation-only). Shares routes with preview.",
      "serverPath": "server/src/services/video-generation/",
      "diFile": "video-generation.services.ts",
      "routes": [
        "POST /api/preview/video/generate (full render mode)",
        "POST /api/generate/consistent (multi-shot)"
      ],
      "clientApi": "client/src/features/generations/, client/src/features/preview/api/",
      "providers": ["openai (sora)", "luma", "fal", "replicate"]
    },
    {
      "key": "sessions",
      "name": "Sessions (v2)",
      "description": "User session state — prompt edits, history, current model, settings. v2 namespace under /api/v2/sessions.",
      "serverPath": "server/src/services/sessions/",
      "diFile": "session.services.ts",
      "routes": [
        "POST /api/v2/sessions",
        "GET /api/v2/sessions",
        "GET /api/v2/sessions/:id",
        "PATCH /api/v2/sessions/:id",
        "POST /api/v2/sessions/:id/snapshots"
      ],
      "clientApi": "(uses ApiClient directly)"
    },
    {
      "key": "assets",
      "name": "Assets + Reference Images",
      "description": "User-uploaded media (reference images, generated outputs). Backed by Google Cloud Storage.",
      "serverPath": "server/src/services/asset/, server/src/services/storage/",
      "diFile": "storage.services.ts, session.services.ts",
      "routes": [
        "GET/POST /api/assets/*",
        "GET/POST/PATCH/DELETE /api/reference-images/*",
        "POST /api/storage/upload",
        "GET /api/storage/signed-url",
        "GET /api/storage/download"
      ],
      "clientApi": "client/src/features/assets/, client/src/features/reference-images/, client/src/api/storageApi.ts"
    },
    {
      "key": "payment",
      "name": "Payment + Credits",
      "description": "Stripe-backed billing, credit balance, invoices, portal sessions, webhook reconciliation.",
      "serverPath": "server/src/services/payment/, server/src/services/credits/",
      "diFile": "payment.services.ts, credit.services.ts",
      "routes": [
        "GET /api/payment/status",
        "GET /api/payment/credits/balance",
        "GET /api/payment/credits/history",
        "GET /api/payment/invoices",
        "POST /api/payment/portal",
        "POST /api/payment/checkout",
        "POST /api/payment/webhook (Stripe)"
      ],
      "clientApi": "client/src/api/billingApi.ts"
    },
    {
      "key": "capabilities",
      "name": "Capabilities Registry",
      "description": "Schema-driven UI capabilities catalog (which models support what features, cost tiers, taxonomy).",
      "serverPath": "(reads from shared/)",
      "diFile": "(no DI — pure routes)",
      "routes": [
        "GET /api/capabilities",
        "GET /api/capabilities/models",
        "GET /api/capabilities/taxonomy",
        "GET /api/capabilities/version"
      ],
      "clientApi": "client/src/services/CapabilitiesApi.ts"
    },
    {
      "key": "health",
      "name": "Health + Liveness",
      "description": "Operational health probes for liveness/readiness checks and Sentry debug endpoint.",
      "serverPath": "server/src/routes/health.routes.ts",
      "diFile": "(no DI)",
      "routes": [
        "GET /health",
        "GET /health/ready",
        "GET /health/live",
        "GET /debug-sentry (dev only)"
      ],
      "clientApi": "(not called from client)"
    }
  ],
  "diRegistration": [
    {
      "file": "core.services.ts",
      "purpose": "Foundation: logger, config, metrics, circuit breaker, Firebase clients, depth/face/image-observation services",
      "registers": [
        "logger",
        "config",
        "metrics",
        "firebaseClients",
        "depthEstimationService",
        "faceEmbeddingService",
        "imageObservationService",
        "llmJudgeService"
      ]
    },
    {
      "file": "observability.services.ts",
      "purpose": "Telemetry plumbing",
      "registers": [
        "postHogClient",
        "openTelemetryTracer",
        "structuredLogger",
        "telemetryEmitter"
      ]
    },
    {
      "file": "cache.services.ts",
      "purpose": "Cache layer (Redis + in-memory)",
      "registers": ["cacheService", "redisClient", "spanLabelingCache"]
    },
    {
      "file": "storage.services.ts",
      "purpose": "GCS-backed object storage",
      "registers": [
        "gcsStorage",
        "gcsBucketName",
        "storageService",
        "videoContentAccess",
        "videoAssetRetention",
        "+ supporting helpers"
      ]
    },
    {
      "file": "credit.services.ts",
      "purpose": "User credit accounting + refunds + reconciliation",
      "registers": [
        "userCreditService",
        "creditReconciliation",
        "creditRefundSweeper",
        "starterCredits",
        "creditLedger"
      ]
    },
    {
      "file": "video-jobs.services.ts",
      "purpose": "Video job queue, DLQ reprocessor, sweeper, idempotency",
      "registers": ["requestIdempotency", "videoJobProcessor"]
    },
    {
      "file": "llm.services.ts",
      "purpose": "AI model routing layer — single point of LLM access",
      "registers": [
        "aiModelService",
        "aiService",
        "concurrencyController",
        "providerHealth",
        "circuitBreaker",
        "promptCache",
        "responseCache"
      ]
    },
    {
      "file": "i2v.services.ts",
      "purpose": "Image-to-video motion idea generation",
      "registers": ["motionIdeaService"]
    },
    {
      "file": "span-labeling.services.ts",
      "purpose": "Taxonomy classification for UI highlights",
      "registers": ["spanLabelingService"]
    },
    {
      "file": "enhancement.services.ts",
      "purpose": "Click-to-enhance suggestions + prompt optimization + scene detection",
      "registers": [
        "enhancementService",
        "videoService",
        "sceneDetectionService",
        "promptCoherenceService",
        "suggestionsTelemetryService",
        "promptBuilder",
        "templateService",
        "promptOptimizationService",
        "optimizeTelemetryService",
        "+ helpers"
      ]
    },
    {
      "file": "video-generation.services.ts",
      "purpose": "Video generation (preview + final render)",
      "registers": [
        "videoGenerationService",
        "keyframeGenerationService",
        "faceSwapService",
        "consistentVideoService",
        "capabilitiesProbeService",
        "providerCircuitManager",
        "videoWorkerHeartbeatStore",
        "videoJobHandler",
        "videoJobWorker",
        "videoJobSweeper",
        "dlqReprocessorWorker",
        "videoJobReconciler"
      ]
    },
    {
      "file": "continuity.services.ts",
      "purpose": "Shot-to-shot continuity (gated on ENABLE_CONVERGENCE)",
      "registers": [
        "continuitySessionService",
        "continuityQualityGate",
        "+ 11 supporting services"
      ],
      "conditional": "ENABLE_CONVERGENCE=true; otherwise continuitySessionService = null"
    },
    {
      "file": "payment.services.ts",
      "purpose": "Stripe payments + webhooks + billing profile repair",
      "registers": [
        "paymentService",
        "billingProfileStore",
        "stripeWebhookWorker",
        "billingProfileRepairWorker",
        "webhookReconciliation",
        "stripeClient"
      ]
    },
    {
      "file": "session.services.ts",
      "purpose": "User session state + asset access + reference images",
      "registers": [
        "sessionStore",
        "sessionService",
        "assetService",
        "referenceImageRepository"
      ]
    }
  ],
  "routes": [
    {
      "method": "POST",
      "path": "/api/optimize",
      "file": "optimize.routes.ts",
      "domain": "optimization",
      "auth": "user",
      "conditional": false
    },
    {
      "method": "POST",
      "path": "/api/optimize/stream",
      "file": "optimize.routes.ts",
      "domain": "optimization",
      "auth": "user",
      "conditional": false
    },
    {
      "method": "POST",
      "path": "/api/get-enhancement-suggestions",
      "file": "enhancement.routes.ts",
      "domain": "enhancement",
      "auth": "user",
      "conditional": false
    },
    {
      "method": "POST",
      "path": "/api/get-custom-suggestions",
      "file": "enhancement.routes.ts",
      "domain": "enhancement",
      "auth": "user",
      "conditional": false
    },
    {
      "method": "POST",
      "path": "/api/detect-scene-change",
      "file": "enhancement.routes.ts",
      "domain": "enhancement",
      "auth": "user",
      "conditional": false
    },
    {
      "method": "POST",
      "path": "/api/test-nlp",
      "file": "enhancement.routes.ts",
      "domain": "enhancement",
      "auth": "dev",
      "conditional": false
    },
    {
      "method": "POST",
      "path": "/llm/label-spans/stream",
      "file": "labelSpansRoute.ts",
      "domain": "span-labeling",
      "auth": "user",
      "conditional": false
    },
    {
      "method": "POST",
      "path": "/llm/role-classify",
      "file": "roleClassifyRoute.ts",
      "domain": "span-labeling",
      "auth": "user",
      "conditional": false
    },
    {
      "method": "*",
      "path": "/api/preview/*",
