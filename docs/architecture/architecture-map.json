  "boundaries": [
    {
      "name": "Client ↔ Server",
      "rule": "Strictly decoupled — client/src never imports server/src and vice versa.",
      "sharedCode": "shared/ (types, Zod, constants, pure utilities only)",
      "antiCorruption": "Each client feature's api/ directory transforms server DTOs into client-friendly shapes."
    },
    {
      "name": "Routes ↔ Services",
      "rule": "Route handlers are thin — all business logic lives in services. Services receive deps via constructor injection.",
      "rationale": "Prevents container.resolve() leakage outside DI config + route factories."
    },
    {
      "name": "Business Service ↔ LLM Provider",
      "rule": "aiService is the only LLM routing layer. No service may call openai/groq/gemini clients directly.",
      "rationale": "Single point for retries, rate limits, caching, and circuit breaking."
    },
    {
      "name": "shared/ Purity",
      "rule": "shared/ code must be pure — no Node APIs, no React, no fetch, no I/O.",
      "rationale": "Same code runs on both server and client — impure imports break one side."
    }
  ],
  "operations": {
    "commands": {
      "dev": "npm start (orchestrator) or npm run dev (client only) + npm run server",
      "test": "npm run test:unit / npm run test:e2e / npm run test:coverage / npm run test:regression",
      "typecheck": "npx tsc --noEmit",
      "lint": "npm run lint / npm run lint:fix / npm run lint:all",
      "build": "npm run build",
      "eval-golden": "npm run eval:golden-set / npm run eval:golden-set:bless",
      "integration-gate": "PORT=0 npx vitest run tests/integration/bootstrap.integration.test.ts tests/integration/di-container.integration.test.ts --config config/test/vitest.integration.config.js"
    },
    "commitProtocol": [
      "npx tsc --noEmit must exit 0",
      "npx eslint --quiet must report 0 errors",
      "npm run test:unit must pass",
      "fix: commits must include a regression test (hook enforced)"
    ],
    "activePrograms": [
      {
        "name": "Measurement Program",
        "doc": "docs/superpowers/programs/measurement.md",
        "goal": "Every surface emits operational + quality telemetry to PostHog with traffic-source discrimination.",
        "subProject0": "Source discriminator + synthetic-traffic harness (in design)"
      }
    ]
  }
