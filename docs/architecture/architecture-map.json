    },
    {
      "method": "*",
      "path": "/api/v2/sessions/*",
      "file": "sessions.routes.ts",
      "domain": "sessions",
      "auth": "user",
      "conditional": "sessionService"
    },
    {
      "method": "POST",
      "path": "/api/model-intelligence/*",
      "file": "model-intelligence.routes.ts",
      "domain": "model-intelligence",
      "auth": "user",
      "conditional": "modelIntelligenceService"
    },
    {
      "method": "POST",
      "path": "/api/motion/*",
      "file": "motion.routes.ts",
      "domain": "convergence",
      "auth": "user",
      "conditional": "motionIdeaService"
    },
    {
      "method": "POST",
      "path": "/api/observe-image",
      "file": "image-observation.routes.ts",
      "domain": "enhancement",
      "auth": "user",
      "conditional": "imageObservationService"
    },
    {
      "method": "*",
      "path": "/api/payment/*",
      "file": "payment.routes.ts",
      "domain": "payment",
      "auth": "user / webhook signature",
      "conditional": false
    },
    {
      "method": "GET",
      "path": "/api/capabilities/*",
      "file": "capabilities.routes.ts",
      "domain": "capabilities",
      "auth": "public",
      "conditional": false
    },
    {
      "method": "GET",
      "path": "/health",
      "file": "health.routes.ts",
      "domain": "health",
      "auth": "public",
      "conditional": false
    },
    {
      "method": "GET",
      "path": "/health/ready",
      "file": "health.routes.ts",
      "domain": "health",
      "auth": "public",
      "conditional": false
    },
    {
      "method": "GET",
      "path": "/health/live",
      "file": "health.routes.ts",
      "domain": "health",
      "auth": "public",
      "conditional": false
    }
  ],
  "clientFeatures": [
    {
      "name": "workspace-shell",
      "purpose": "Top-level layout, panels, navigation",
      "consumes": []
    },
    {
      "name": "prompt-optimizer",
      "purpose": "Two-stage prompt rewrite (Groq draft → OpenAI refine) with diff UI",
      "consumes": ["/api/optimize"]
    },
    {
      "name": "span-highlighting",
